{
  "name": "unimask",
  "version": "1.0.2",
  "description": "A lightweight utility library for creating mask for input values",
  "keywords": [
    "formatting",
    "input",
    "mask",
    "masking",
    "string",
    "vue-formatting",
    "vue-mask"
  ],
  "homepage": "https://github.com/dschewchenko/unimask#readme",
  "bugs": {
    "url": "https://github.com/dschewchenko/unimask/issues"
  },
  "license": "MIT",
  "author": "dschewchenko",
  "repository": {
    "type": "git",
    "url": "https://github.com/dschewchenko/unimask.git"
  },
  "files": [
    "dist/*",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "vue": [
        "./dist/vue/index.d.ts"
      ],
      "react": [
        "./dist/react/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint src vite.config.ts --ignore-path .gitignore && oxfmt --check package.json tsconfig.json vite.config.ts 'src/**/*.ts'",
    "lint:fix": "oxfmt --write package.json tsconfig.json vite.config.ts 'src/**/*.ts' && oxlint src vite.config.ts --fix --ignore-path .gitignore",
    "prepare": "husky",
    "husky:pre-commit": "bun run lint",
    "prepublishOnly": "bun run build",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "react": "^19.2.7",
    "semantic-release": "^25.0.5",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ],
    "branches": [
      "main"
    ]
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22.14.0"
  },
  "packageManager": "bun@1.3.13"
}
